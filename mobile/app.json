{
  "expo": {
    "name": "MotiveFX.AI",
    "slug": "motivefx",
    "version": "0.1.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "motivefx",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080a0c"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.motivefx.app",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        },
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "6"
    },
    "android": {
      "package": "ai.motivefx.app",
      "versionCode": 5,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080a0c"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "INTERNET",
        "VIBRATE"
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#080a0c",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "be5b49f1-61c1-4d22-960d-12a3a898f913"
      }
    }
  }
}
