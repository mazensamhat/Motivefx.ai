{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://motivefx.ai/api",
        "EXPO_PUBLIC_WEB_URL": "https://motivefx.ai",
        "EXPO_PUBLIC_TERMINAL_URL": "https://motivefx.ai/terminal/"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://motivefx.ai/api",
        "EXPO_PUBLIC_WEB_URL": "https://motivefx.ai",
        "EXPO_PUBLIC_TERMINAL_URL": "https://motivefx.ai/terminal/"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}
