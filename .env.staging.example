# Copy to .env.staging and fill in before staging deploy:
#   copy .env.staging.example .env.staging

# ── Public URLs (must match how users reach the app) ──
APP_PUBLIC_URL=https://staging.motivefx.ai
CORS_ORIGINS=https://staging.motivefx.ai,http://localhost:8080

# ── Secrets — generate with: scripts/generate-secrets.ps1 ──
JWT_SECRET_KEY=
ADMIN_API_KEY=

# ── Auth / email ──
AUTH_ENFORCE=true
EXPOSE_RESET_LINKS=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@motivefx.ai

# ── Stripe (use test keys for staging) ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_TRADES=price_...
STRIPE_PRICE_CRYPTO=price_...
STRIPE_PRICE_BETTING=price_...
STRIPE_PRICE_PENNY=price_...
STRIPE_PRICE_PREDICTIONS=price_...
STRIPE_PRICE_ANNUAL=price_...
STRIPE_PRICE_BUNDLE=price_...
ANNUAL_PRICE_USD=799
BUNDLE_PRICE_USD=109

# ── Data feeds ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
FINNHUB_API_KEY=
TWELVE_DATA_API_KEY=
THE_ODDS_API_KEY=
COINSTATS_API_KEY=

# ── Docker compose local port (web/nginx) ──
STAGING_WEB_PORT=8080
