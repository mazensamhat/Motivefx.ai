# Local overrides for Expo — copy to .env (not committed)
# Production API lives on www.motivefxai.com (not motivefx.ai)
EXPO_PUBLIC_API_URL=https://www.motivefxai.com/api
EXPO_PUBLIC_WEB_URL=https://www.motivefxai.com
EXPO_PUBLIC_TERMINAL_URL=https://www.motivefxai.com/terminal/

# Android emulator → host machine (when running site locally on :3010)
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3010/api
# EXPO_PUBLIC_WEB_URL=http://10.0.2.2:3010
# EXPO_PUBLIC_TERMINAL_URL=http://10.0.2.2:3010/terminal/
