# Points-based — not unlimited free. Signup: https://account.bitquery.io
# Prefer OAuth access token (ory_at_…) OR client credentials (production).
# Docs: https://docs.bitquery.io/docs/authorisation/how-to-generate/
# BITQUERY_API_KEY=
# BITQUERY_CLIENT_ID=
# BITQUERY_CLIENT_SECRET=
# BITQUERY_ENABLED=true
COINSTATS_API_KEY=

